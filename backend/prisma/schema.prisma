generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

enum Provider {
  local
  Github
  Google
}

enum GameType {
  mergeGame
  decrypto
  eventLoop
  hangman
  citiesGame
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String   @default("null")
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatar    String?   
  provider  Provider @default(local)
  providerId String?  @unique
  refreshToken String?
  stats     GameStatistic[]

  @@map("users")
}


model GameStatistic {
  id   Int   @id @default(autoincrement())
  userId    String

  gameType  GameType 
  updatedAt DateTime    @updatedAt
  playedCount Int @default(1)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, gameType])
  @@map("game_statistic")
}

model Storage {
  id String @id @default(uuid())
  key String @unique
  storage Json

  @@map("storages")
}

model MergeGameData {
  id       Int      @id @default(autoincrement())
  category String
  words    Word[]

  @@index([category])
  @@map("merge_game_data")
}

model Word {
  id        Int             @id @default(autoincrement())
  word      String
  dataId    Int
  data      MergeGameData   @relation(fields: [dataId], references: [id], onDelete: Cascade)
  questions Question[]

  @@index([dataId])
  @@map("merge_game_word")
}

model Question {
  id       Int      @id @default(autoincrement())
  question String
  answer   String
  keywords String[]
  wordId   Int
  word     Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId])
  @@map("merge_game_question")
}