# ==========================================
# MeowVault - Environment Variables
# ==========================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env
# ==========================================

# ------------------------------------------
# PostgreSQL Database
# ------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password
POSTGRES_DB=postgres

# ------------------------------------------
# Backend (NestJS)
# ------------------------------------------
MODE=product
PORT=4000
HOST=http://localhost
DEV_HOST=http://localhost:8080
DEPLOY_URL_CORS=/^https:\/\/(deploy-preview-\d+--)?meowvault\.netlify\.app$/

BCRYPT_SALT=10
JWT_SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_ACCESS_TOKEN_EXPIRE_TIME=1h
JWT_REFRESH_TOKEN_EXPIRE_TIME=7d

# Prisma: URL для миграций (Docker использует хост 'meowvault-postgres')
DIRECT_URL=postgresql://postgres:your-strong-password@meowvault-postgres:5432/postgres
DEVELOPMENT_POSTGRES=postgresql://postgres:123456@meowvault-postgres:5432/postgres

# GitHub OAuth2
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
CALLBACK_URL=http://localhost:4000/auth/github/callback
REDIRECT_FRONTEND=http://localhost:8080/

# AI (Optional)
AI_KEY=key
AI_MODEL=model
AI_URL=url

# ------------------------------------------
# Frontend (Angular)
# ------------------------------------------
# URL бэкенда для API запросов
NG_APP_API_URL=http://localhost:4000

# Cloudinary (Optional)
NG_APP_CLOUDINARY_CLOUD_NAME=
NG_APP_CLOUDINARY_UPLOAD_PRESET=
NG_APP_CLOUDINARY_UPLOAD_URL=
